#!/usr/bin/env bash
set -euo pipefail

SECRETS_FILE="${SONARQUBE_ENV_FILE:-$HOME/.config/sonarqube/sonar.env}"

if [[ -f "$SECRETS_FILE" ]]; then
    while IFS='=' read -r key value || [[ -n "$key" ]]; do
        case "$key" in
            ''|\#*) continue ;;
            SONARQUBE_TOKEN|SONARQUBE_ORG|SONAR_TOKEN|SONAR_ORGANIZATION|SONAR_HOST_URL|SONARQUBE_URL)
                export "$key=$value"
                ;;
        esac
    done < "$SECRETS_FILE"
fi

if [[ -n "${SONARQUBE_TOKEN:-}" ]]; then
    export SONAR_TOKEN="$SONARQUBE_TOKEN"
fi

if [[ -z "${SONAR_HOST_URL:-}" && -n "${SONARQUBE_URL:-}" ]]; then
    export SONAR_HOST_URL="$SONARQUBE_URL"
fi

export SONAR_HOST_URL="${SONAR_HOST_URL:-https://sonarcloud.io}"

REPORT="${SONAR_CPP_COVERAGE_REPORT:-coverage.xml}"
BUILD_DIR="${SONAR_CPP_BUILD_DIR:-build/coverage}"
read -r -a SONAR_CPP_CMAKE_EXTRA_ARGS <<< "${SONAR_CPP_CMAKE_ARGS:-}"
read -r -a SONAR_CPP_CTEST_EXTRA_ARGS <<< "${SONAR_CPP_CTEST_ARGS:-}"
read -r -a SONAR_CPP_GCOVR_EXTRA_ARGS <<< "${SONAR_CPP_GCOVR_ARGS:-}"

if [[ -z "${SONAR_TOKEN:-}" ]]; then
    echo "Missing SONAR_TOKEN or SONARQUBE_TOKEN." >&2
    echo "Put it in $SECRETS_FILE or export it before running this command." >&2
    exit 2
fi

if ! command -v sonar-scanner >/dev/null 2>&1; then
    echo "sonar-scanner is not on PATH. Rebuild/reopen the devBench base image first." >&2
    exit 2
fi

if [[ "${SONAR_SKIP_TESTS:-0}" != "1" ]]; then
    if [[ -n "${SONAR_CPP_TEST_COMMAND:-}" ]]; then
        bash -lc "$SONAR_CPP_TEST_COMMAND"
    elif [[ -f CMakeLists.txt ]]; then
        cmake -S . -B "$BUILD_DIR" -G Ninja \
            -DCMAKE_BUILD_TYPE=Debug \
            -DCMAKE_C_FLAGS="${CMAKE_C_FLAGS:-} --coverage" \
            -DCMAKE_CXX_FLAGS="${CMAKE_CXX_FLAGS:-} --coverage" \
            -DCMAKE_EXE_LINKER_FLAGS="${CMAKE_EXE_LINKER_FLAGS:-} --coverage" \
            "${SONAR_CPP_CMAKE_EXTRA_ARGS[@]}"
        cmake --build "$BUILD_DIR" --parallel "$(nproc)"
        ctest --test-dir "$BUILD_DIR" --output-on-failure "${SONAR_CPP_CTEST_EXTRA_ARGS[@]}"
    else
        echo "No CMakeLists.txt found and SONAR_CPP_TEST_COMMAND is not set." >&2
        echo "Set SONAR_CPP_TEST_COMMAND to your clean coverage build/test command." >&2
        exit 2
    fi

    gcovr --root . --sonarqube "$REPORT" "${SONAR_CPP_GCOVR_EXTRA_ARGS[@]}"
elif [[ ! -f "$REPORT" ]]; then
    echo "SONAR_SKIP_TESTS=1 was set, but $REPORT does not exist." >&2
    exit 2
fi

sonar-scanner -Dsonar.coverageReportPaths="$REPORT" "$@"
