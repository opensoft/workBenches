#!/usr/bin/env bash
set -euo pipefail

SECRETS_FILE="${SONARQUBE_ENV_FILE:-$HOME/.config/sonarqube/sonar.env}"
if [[ ! -f "$SECRETS_FILE" && -f "$HOME/.config/ledgerlinc/secrets/sonar.env" ]]; then
    SECRETS_FILE="$HOME/.config/ledgerlinc/secrets/sonar.env"
fi

if [[ -f "$SECRETS_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$SECRETS_FILE"
    set +a
fi

if [[ -z "${SONAR_TOKEN:-}" && -n "${SONARQUBE_TOKEN:-}" ]]; then
    export SONAR_TOKEN="$SONARQUBE_TOKEN"
fi

if [[ -z "${SONAR_HOST_URL:-}" && -n "${SONARQUBE_URL:-}" ]]; then
    export SONAR_HOST_URL="$SONARQUBE_URL"
fi

export SONAR_HOST_URL="${SONAR_HOST_URL:-https://sonarcloud.io}"
export SONAR_GRADLE_PLUGIN_VERSION="${SONAR_GRADLE_PLUGIN_VERSION:-7.3.0.8198}"

if [[ -z "${SONAR_TOKEN:-}" ]]; then
    echo "Missing SONAR_TOKEN or SONARQUBE_TOKEN." >&2
    echo "Put it in $SECRETS_FILE or export it before running this command." >&2
    exit 2
fi

if [[ ! -f build.gradle && ! -f build.gradle.kts ]]; then
    echo "build.gradle or build.gradle.kts not found. Run this from the Gradle project root." >&2
    exit 2
fi

if [[ -x ./gradlew ]]; then
    GRADLE_CMD=(./gradlew)
else
    GRADLE_CMD=(gradle)
fi

if ! grep -Eq '(^|[^[:alnum:]_.-])jacoco([^[:alnum:]_.-]|$)' build.gradle* 2>/dev/null; then
    echo "Warning: this project does not appear to apply the Gradle jacoco plugin." >&2
fi

if ! grep -Eq 'org\.sonarqube|sonarqube' build.gradle* 2>/dev/null; then
    echo "Warning: this project does not appear to apply the org.sonarqube Gradle plugin." >&2
    echo "Use plugin version ${SONAR_GRADLE_PLUGIN_VERSION} unless the project pins another version." >&2
fi

exec "${GRADLE_CMD[@]}" test jacocoTestReport "${SONAR_GRADLE_TASK:-sonarqube}" "$@"
