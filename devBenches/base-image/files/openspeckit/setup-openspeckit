def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Prepare a repo for the shared OpenSpec/Speckit agent workflow."
    )
    parser.add_argument("--repo", type=Path, help="Repository root. Defaults to git root.")
    parser.add_argument("--dry-run", action="store_true", help="Print planned changes only.")
    parser.add_argument("--force", action="store_true", help="Overwrite existing copied helpers.")
    parser.add_argument(
        "--preserve-readmes",
        action="store_true",
        help="Do not rewrite openspec/README.md or .specify/README.md.",
    )
    parser.add_argument(
        "--skip-init",
        action="store_true",
        help="Do not create minimal openspec/.specify scaffolding or run specify init.",
    )
    parser.add_argument(
        "--integration",
        help="Spec Kit integration to install when initialization is needed. Defaults to existing integration or claude.",
    )
    parser.add_argument(
        "--no-speckit-registration",
        action="store_true",
        help="Do not register the Spec Kit git extension or bundled speckit workflow.",
    )
    parser.add_argument(
        "--no-worktrees",
        action="store_true",
        help="Do not install the Speckit worktree overlay.",
    )
    parser.add_argument(
        "--base-branch",
        help="Base branch for new Speckit worktrees. Defaults to main when present, otherwise current branch.",
    )
    parser.add_argument(
        "--worktree-root",
        help="Worktree parent path, relative to repo root unless absolute. Defaults to ../<repo-name>-worktrees.",
    )
    parser.add_argument(
        "--no-skill-links",
        action="store_true",
        help="Do not link global skills into repo-local agent folders.",
    )
    parser.add_argument(
        "--no-global-agent-pointers",
        action="store_true",
        help="Do not update user-global agent entrypoint files.",
    )
    parser.add_argument(
        "--no-repo-agent-pointers",
        action="store_true",
        help="Do not update repo-local context files for supported agents.",
    )
    return parser.parse_args()


def log(message: str) -> None:
    print(message)


def run_command(command: list[str], cwd: Path, dry_run: bool) -> None:
    printable = " ".join(shlex_quote(part) for part in command)
    if dry_run:
        log(f"would run ({cwd}): {printable}")
        return
    log(f"running ({cwd}): {printable}")
    subprocess.run(command, cwd=cwd, check=True)


def shlex_quote(value: str) -> str:
    if not value:
        return "''"
    safe = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_+-=.,/:@%"
    if all(char in safe for char in value):
        return value
    return "'" + value.replace("'", "'\"'\"'") + "'"


def git_root() -> Path:
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
    except (OSError, subprocess.CalledProcessError) as exc:
        raise SystemExit(
            "Could not determine repo root. Run inside a git repo or pass --repo."
        ) from exc
    return Path(result.stdout.strip()).resolve()


def read_json(path: Path) -> dict[str, object]:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}


def existing_integration(repo: Path) -> str | None:
    integration_state = read_json(repo / ".specify" / "integration.json")
    value = integration_state.get("integration") or integration_state.get("default_integration")
    if isinstance(value, str) and value:
        return value

    init_options = read_json(repo / ".specify" / "init-options.json")
    value = init_options.get("integration") or init_options.get("ai")
    if isinstance(value, str) and value:
        return value

    return None


def needs_speckit_init(repo: Path) -> bool:
    required = [
        repo / ".specify" / "init-options.json",
        repo / ".specify" / "integration.json",
        repo / ".specify" / "templates" / "spec-template.md",
    ]
    return any(not path.exists() for path in required)


def ensure_speckit_initialized(
    repo: Path,
    integration: str,
    dry_run: bool,
    skip_init: bool,
) -> None:
    if skip_init or not needs_speckit_init(repo):
        return

    command = [
        "specify",
        "init",
        "--here",
        "--force",
        "--integration",
        integration,
        "--script",
        "sh",
        "--ai-skills",
        "--ignore-agent-tools",
    ]
    run_command(command, repo, dry_run)


def git_extension_registered(repo: Path) -> bool:
    registry = read_json(repo / ".specify" / "extensions" / ".registry")
    extensions = registry.get("extensions")
    if not isinstance(extensions, dict):
        return False
    git_extension = extensions.get("git")
    return isinstance(git_extension, dict) and git_extension.get("enabled") is True


def speckit_workflow_registered(repo: Path) -> bool:
    registry = read_json(repo / ".specify" / "workflows" / "workflow-registry.json")
    workflows = registry.get("workflows")
    return isinstance(workflows, dict) and "speckit" in workflows


def ensure_speckit_registration(repo: Path, dry_run: bool, skip_registration: bool) -> None:
    if skip_registration:
        return
    if not git_extension_registered(repo):
        run_command(["specify", "extension", "add", "git"], repo, dry_run)
    else:
        log("unchanged Speckit git extension registration")
    if not speckit_workflow_registered(repo):
        run_command(["specify", "workflow", "add", "speckit"], repo, dry_run)
    else:
        log("unchanged Speckit workflow registration")


def write_text(path: Path, text: str, dry_run: bool) -> None:
    if path.exists() and path.read_text(encoding="utf-8") == text:
        log(f"unchanged {path}")
        return
    if dry_run:
        log(f"would write {path}")
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(text, encoding="utf-8")
    log(f"wrote {path}")


def touch(path: Path, dry_run: bool) -> None:
    if path.exists():
        return
    if dry_run:
        log(f"would create {path}")
        return
    path.parent.mkdir(parents=True, exist_ok=True)
    path.touch()
    log(f"created {path}")


def upsert_block(path: Path, block_body: str, dry_run: bool) -> None:
    block = f"{START}\n{block_body.rstrip()}\n{END}\n"
    if path.exists():
        text = path.read_text(encoding="utf-8")
    else:
        text = "# Agent Instructions\n\n"

    if START in text and END in text:
        before, remainder = text.split(START, 1)
        _, after = remainder.split(END, 1)
        after = after.lstrip("\n")
        separator = "\n" if after else ""
        new_text = before.rstrip() + "\n\n" + block + separator + after
    else:
        marker = "\n## "
        index = text.find(marker)
        if index == -1:
            new_text = text.rstrip() + "\n\n" + block
        else:
            new_text = text[:index].rstrip() + "\n\n" + block + "\n" + text[index + 1 :]

    write_text(path, new_text, dry_run)


def copy_missing_tree(src: Path, dst: Path, dry_run: bool, force: bool) -> None:
    if not src.exists():
        return
    for source in sorted(src.rglob("*")):
        if source.is_dir():
            continue
        target = dst / source.relative_to(src)
        if target.exists() and not force:
            log(f"kept existing {target}")
            continue
        if dry_run:
            log(f"would copy {source} -> {target}")
            continue
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)
        log(f"copied {source} -> {target}")


def link_or_copy_skill(src: Path, dst: Path, dry_run: bool, force: bool) -> None:
    if not src.exists():
        return
    if dst.exists() or dst.is_symlink():
        if not force:
            log(f"kept existing {dst}")
            return
        if dry_run:
            log(f"would replace {dst}")
            return
        if dst.is_symlink() or dst.is_file():
            dst.unlink()
        else:
            shutil.rmtree(dst)
    if dry_run:
        log(f"would link {src} -> {dst}")
        return
    dst.parent.mkdir(parents=True, exist_ok=True)
    try:
        dst.symlink_to(src, target_is_directory=True)
        log(f"linked {src} -> {dst}")
    except OSError:
        shutil.copytree(src, dst)
        log(f"copied {src} -> {dst}")


def copy_overlay_tree(src: Path, dst: Path, dry_run: bool, force: bool) -> None:
    if not src.exists():
        return
    for source in sorted(src.rglob("*")):
        if source.is_dir():
            continue
        target = dst / source.relative_to(src)
        if target.exists() and target.read_bytes() == source.read_bytes():
            log(f"unchanged {target}")
            continue
        if target.exists() and not force:
            log(f"kept existing {target} (use --force to replace)")
            continue
        if dry_run:
            log(f"would copy {source} -> {target}")
            continue
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)
        if target.suffix in {".sh", ".zsh", ".ps1"}:
            target.chmod(0o755)
        log(f"copied {source} -> {target}")


def can_write_path_or_parent(path: Path) -> bool:
    if path.exists():
        return os.access(path, os.W_OK)
    parent = path.parent
    while not parent.exists() and parent != parent.parent:
        parent = parent.parent
    return os.access(parent, os.W_OK)


