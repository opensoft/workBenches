def ensure_scaffold(repo: Path, dry_run: bool, skip_init: bool) -> None:
    if skip_init:
        return
    for directory in [
        repo / "openspec" / "changes" / "archive",
        repo / "openspec" / "specs",
        repo / ".specify",
    ]:
        if dry_run:
            if not directory.exists():
                log(f"would create directory {directory}")
        else:
            directory.mkdir(parents=True, exist_ok=True)
    touch(repo / "openspec" / "changes" / "archive" / ".gitkeep", dry_run)
    touch(repo / "openspec" / "specs" / ".gitkeep", dry_run)


def ensure_skills(repo: Path, dry_run: bool, force: bool) -> None:
    homes = {
        ".claude": Path.home() / ".claude" / "skills",
        ".codex": Path.home() / ".codex" / "skills",
        ".agents": Path.home() / ".agents" / "skills",
    }
    for agent_dir, source_root in homes.items():
        for skill in SKILLS:
            link_or_copy_skill(
                source_root / skill,
                repo / agent_dir / "skills" / skill,
                dry_run,
                force,
            )


def ensure_repo_agent_pointers(repo: Path, agent_root: Path, dry_run: bool) -> None:
    seen: set[str] = set()
    for _, relative_path in SUPPORTED_AGENT_CONTEXT_FILES:
        if relative_path in seen:
            continue
        seen.add(relative_path)
        upsert_block(repo / relative_path, agent_block(agent_root), dry_run)


def ensure_global_agent_pointers(agent_root: Path, dry_run: bool) -> None:
    for relative_path in USER_GLOBAL_AGENT_POINTER_FILES:
        path = Path.home() / relative_path
        if dry_run and not can_write_path_or_parent(path):
            log(f"skipped {path}: permission denied")
            continue
        try:
            upsert_block(path, global_pointer_block(agent_root), dry_run)
        except PermissionError as exc:
            log(f"skipped {path}: permission denied ({exc})")
        except OSError as exc:
            log(f"skipped {path}: {exc}")


def worktree_template_root() -> Path | None:
    candidates: list[Path] = []
    env_root = os.environ.get("SPECKIT_WORKTREE_TEMPLATE_ROOT")
    if env_root:
        candidates.append(Path(env_root))
    candidates.append(Path("/usr/local/share/speckit-worktree/templates"))

    script_path = Path(__file__).resolve()
    candidates.append(script_path.parent.parent / "speckit-worktree" / "templates")
    candidates.append(
        Path.home()
        / "projects"
        / "workBenches"
        / "devBenches"
        / "base-image"
        / "files"
        / "speckit-worktree"
        / "templates"
    )

    for candidate in candidates:
        if candidate.is_dir():
            return candidate
    return None


def default_base_branch(repo: Path) -> str:
    for ref in ["refs/heads/main", "refs/remotes/origin/main"]:
        if subprocess.run(
            ["git", "-C", str(repo), "show-ref", "--verify", "--quiet", ref],
            check=False,
        ).returncode == 0:
            return "main"

    result = subprocess.run(
        ["git", "-C", str(repo), "rev-parse", "--abbrev-ref", "HEAD"],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    branch = result.stdout.strip()
    if result.returncode == 0 and branch and branch != "HEAD":
        return branch
    return "main"


def set_top_level_yml_values(path: Path, values: dict[str, str], dry_run: bool) -> None:
    if path.exists():
        lines = path.read_text(encoding="utf-8").splitlines()
    else:
        lines = [
            "# Git Branching Workflow Extension Configuration",
            "# Managed by setup-openspeckit. Rerun after Speckit upgrades.",
            "",
            "# Branch numbering strategy: \"sequential\" (001, 002, ...) or \"timestamp\" (YYYYMMDD-HHMMSS)",
            "branch_numbering: sequential",
            "",
            "# Feature checkout strategy: \"branch\" keeps work in the current checkout,",
            "# \"worktree\" creates a sibling worktree rooted from base_branch.",
            "checkout_mode: worktree",
            "",
            "# Base branch for new worktree-backed features. Ignored in branch mode.",
            "base_branch: main",
            "",
            "# Parent directory for linked worktrees. Relative paths resolve from the repo root.",
            "worktree_root: ../example-worktrees",
            "",
            "# Auto-commit before/after core commands. Disabled by default.",
            "auto_commit:",
            "  default: false",
        ]

    seen: set[str] = set()
    updated: list[str] = []
    for line in lines:
        stripped = line.lstrip()
        indent = len(line) - len(stripped)
        replaced = False
        if indent == 0 and ":" in stripped:
            key = stripped.split(":", 1)[0].strip()
            if key in values:
                updated.append(f"{key}: {values[key]}")
                seen.add(key)
                replaced = True
        if not replaced:
            updated.append(line)

    missing = [key for key in values if key not in seen]
    if missing:
        insertion = [f"{key}: {values[key]}" for key in missing]
        if updated and updated[-1].strip():
            updated.append("")
        updated.extend(insertion)

    write_text(path, "\n".join(updated) + "\n", dry_run)


def ensure_extensions_hook(repo: Path, dry_run: bool) -> None:
    path = repo / ".specify" / "extensions.yml"
    hook_text = "speckit.git.feature"
    if path.exists() and hook_text in path.read_text(encoding="utf-8"):
        log(f"unchanged {path}")
        return

    if path.exists():
        lines = path.read_text(encoding="utf-8").splitlines()
    else:
        lines = [
            "installed:",
            "- git",
            "settings:",
            "  auto_execute_hooks: true",
            "hooks:",
        ]

    hook = [
        "- extension: git",
        "  command: speckit.git.feature",
        "  enabled: true",
        "  optional: false",
        "  prompt: Execute speckit.git.feature?",
        "  description: Create feature checkout before specification",
        "  condition: null",
    ]

    for index, line in enumerate(lines):
        if line.strip() == "before_specify:":
            child_indent = line[: len(line) - len(line.lstrip(" "))] + "  "
            lines[index + 1 : index + 1] = [child_indent + item for item in hook]
            write_text(path, "\n".join(lines) + "\n", dry_run)
            return

    for index, line in enumerate(lines):
        if line.strip() == "hooks:":
            child_indent = line[: len(line) - len(line.lstrip(" "))] + "  "
            lines[index + 1 : index + 1] = (
                [child_indent + "before_specify:"]
                + [child_indent + "  " + item for item in hook]
            )
            write_text(path, "\n".join(lines) + "\n", dry_run)
            return

    if lines and lines[-1].strip():
        lines.append("")
    lines.extend(["hooks:", "  before_specify:"] + ["    " + item for item in hook])
    write_text(path, "\n".join(lines) + "\n", dry_run)


def ensure_worktree_overlay(
    repo: Path,
    dry_run: bool,
    force: bool,
    base_branch: str | None,
    worktree_root: str | None,
    skip_worktrees: bool,
) -> None:
    if skip_worktrees:
        return

    template_root = worktree_template_root()
    if template_root is None:
        raise SystemExit("Speckit worktree template root not found.")

    copy_overlay_tree(template_root / "specify" / "extensions" / "git", repo / ".specify" / "extensions" / "git", dry_run, force)
    copy_overlay_tree(template_root / "specify" / "shell", repo / ".specify" / "shell", dry_run, force)
    copy_overlay_tree(template_root / "agents" / "skills" / "speckit-specify", repo / ".agents" / "skills" / "speckit-specify", dry_run, force)
    copy_overlay_tree(template_root / "agents" / "skills" / "speckit-git-feature", repo / ".agents" / "skills" / "speckit-git-feature", dry_run, force)
    copy_overlay_tree(template_root / "claude" / "skills" / "speckit-specify", repo / ".claude" / "skills" / "speckit-specify", dry_run, force)
    copy_overlay_tree(template_root / "claude" / "skills" / "speckit-git-feature", repo / ".claude" / "skills" / "speckit-git-feature", dry_run, force)
    copy_overlay_tree(template_root / "codex" / "skills" / "speckit-specify", repo / ".codex" / "skills" / "speckit-specify", dry_run, force)
    copy_overlay_tree(template_root / "codex" / "skills" / "speckit-git-feature", repo / ".codex" / "skills" / "speckit-git-feature", dry_run, force)

    resolved_base_branch = base_branch or default_base_branch(repo)
    resolved_worktree_root = worktree_root or f"../{repo.name}-worktrees"
    set_top_level_yml_values(
        repo / ".specify" / "extensions" / "git" / "git-config.yml",
        {
            "branch_numbering": "sequential",
            "checkout_mode": "worktree",
            "base_branch": resolved_base_branch,
            "worktree_root": resolved_worktree_root,
        },
        dry_run,
    )
    ensure_extensions_hook(repo, dry_run)


def main() -> int:
    args = parse_args()
    repo = (args.repo.resolve() if args.repo else git_root())
    agent_root = Path(os.environ.get("AGENT_PROTOCOL_ROOT", Path.home() / ".agents")).resolve()
    integration = args.integration or existing_integration(repo) or "claude"

    log(f"repo: {repo}")
    log(f"agent root: {agent_root}")
    log(f"integration: {integration}")

    ensure_scaffold(repo, args.dry_run, args.skip_init)
    ensure_speckit_initialized(repo, integration, args.dry_run, args.skip_init)
    ensure_speckit_registration(repo, args.dry_run, args.no_speckit_registration)
    ensure_worktree_overlay(
        repo,
        args.dry_run,
        args.force,
        args.base_branch,
        args.worktree_root,
        args.no_worktrees,
    )

    if not args.no_repo_agent_pointers:
        ensure_repo_agent_pointers(repo, agent_root, args.dry_run)

    if not args.preserve_readmes:
        write_text(repo / "openspec" / "README.md", openspec_readme(agent_root), args.dry_run)
        write_text(repo / ".specify" / "README.md", specify_readme(agent_root), args.dry_run)

    template_root = agent_root / "templates" / "claude" / "commands" / "opsx"
    copy_missing_tree(
        template_root,
        repo / ".claude" / "commands" / "opsx",
        args.dry_run,
        args.force,
    )

    if not args.no_skill_links:
        ensure_skills(repo, args.dry_run, args.force)

    if not args.no_global_agent_pointers:
        ensure_global_agent_pointers(agent_root, args.dry_run)

    log("done")
    return 0


if __name__ == "__main__":
    sys.exit(main())
