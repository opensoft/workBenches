#!/usr/bin/env bash
set -euo pipefail

manifest="${CLAUDE_PROFILES_MANIFEST:-${XDG_CONFIG_HOME:-$HOME/.config}/workbenches/claude-profiles.json}"
base="${CLAUDE_PROFILES_HOME:-$HOME/.claude-profiles}"
command -v jq >/dev/null 2>&1 || { echo "jq is required." >&2; exit 1; }
[[ -f "$manifest" ]] || { echo "Missing manifest: $manifest" >&2; exit 1; }

action="${1:-list}"
if [[ "$action" == "list" || "$action" == "login" || "$action" == "status" || "$action" == "run" ]]; then
  [[ $# -eq 0 ]] || shift
else
  action="run"
fi

case "$action" in
  list)
    jq -r '.profiles[] | [.name, .family, .email] | @tsv' "$manifest"
    ;;
  login|status|run)
    profile="${1:?Usage: claude-profile $action PROFILE [arguments]}"; shift
    row="$(jq -r --arg name "$profile" '.profiles[] | select(.name == $name) | [.email,.family] | @tsv' "$manifest")"
    [[ -n "$row" ]] || { echo "Unknown Claude profile: $profile" >&2; exit 2; }
    IFS=$'\t' read -r email family <<<"$row"
    config_dir="$base/profiles/$profile"
    case "$action" in
      login) CLAUDE_CONFIG_DIR="$config_dir" claude auth login --claudeai --email "$email" "$@" ;;
      status) CLAUDE_CONFIG_DIR="$config_dir" claude auth status "${@---text}" ;;
      run) CLAUDE_CONFIG_DIR="$config_dir" exec claude "$@" ;;
    esac
    ;;
  *) echo "Usage: claude-profile {list|login|status|run} [PROFILE]" >&2; exit 2 ;;
esac
