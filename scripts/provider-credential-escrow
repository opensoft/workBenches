#!/usr/bin/env bash
set -euo pipefail
umask 077

repo_dir=""
provider=""
profile=""
identity_file=""
force=false
all=false
action="${1:-}"
[[ -n "$action" ]] && shift

usage() {
  cat <<'EOF'
Usage: provider-credential-escrow {backup|restore|check} --repo PATH --provider {claude|openai} [--profile NAME|--all] --identity-file PATH [--force]

Backs up or restores one provider credential using the credentialRef declared
in ai/source.json. Plaintext is read and written only through mode-0600
temporary files and is never printed.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo) repo_dir="$2"; shift 2 ;;
    --provider) provider="$2"; shift 2 ;;
    --profile) profile="$2"; shift 2 ;;
    --identity-file) identity_file="$2"; shift 2 ;;
    --all) all=true; shift ;;
    --force) force=true; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown option: $1" >&2; usage >&2; exit 2 ;;
  esac
done

[[ "$action" =~ ^(backup|restore|check)$ ]] || { usage >&2; exit 2; }
[[ "$provider" =~ ^(claude|openai)$ ]] || { echo "Error: supported providers are claude and openai." >&2; exit 2; }
[[ -d "$repo_dir/.git" && -f "$repo_dir/ai/source.json" ]] || { echo "Error: invalid credential registry: $repo_dir" >&2; exit 1; }
[[ "$all" == true || -n "$profile" ]] || { echo "Error: use --profile or --all." >&2; exit 2; }
[[ -r "$identity_file" ]] || { echo "Error: recovery identity is not readable: $identity_file" >&2; exit 1; }
[[ "$(stat -c '%a' "$identity_file" 2>/dev/null || stat -f '%Lp' "$identity_file")" == 600 ]] || {
  echo "Error: recovery identity must have mode 0600: $identity_file" >&2; exit 1;
}
command -v jq >/dev/null || { echo "Error: jq is required." >&2; exit 1; }
command -v sops >/dev/null || { echo "Error: sops is required." >&2; exit 1; }

case "$provider" in
  claude) profile_root="${CLAUDE_PROFILES_HOME:-$HOME/.claude-profiles}/profiles"; credential_name=".credentials.json" ;;
  openai) profile_root="${CODEX_PROFILES_HOME:-$HOME/.chatgpt-profiles}/profiles"; credential_name="auth.json" ;;
esac

validate_plaintext() {
  local value=$1
  case "$provider" in
    claude) jq -e 'type == "object" and (.claudeAiOauth.accessToken | type == "string" and length > 0)' "$value" >/dev/null ;;
    openai) jq -e 'type == "object" and (((.personal_access_token? | type == "string") and (.personal_access_token | length > 0)) or ((.tokens.access_token? | type == "string") and (.tokens.access_token | length > 0)))' "$value" >/dev/null ;;
  esac
}

json_hash() {
  jq -S -c . "$1" | sha256sum | awk '{print $1}'
}

mapfile -t profiles < <(
  if [[ "$all" == true ]]; then
    jq -r --arg provider "$provider" '.profiles[$provider][] | .name' "$repo_dir/ai/source.json"
  else
    printf '%s\n' "$profile"
  fi
)

export SOPS_AGE_KEY_FILE="$identity_file"
for profile in "${profiles[@]}"; do
  record="$(jq -ce --arg provider "$provider" --arg profile "$profile" '
    .profiles[$provider][] | select(.name == $profile)
  ' "$repo_dir/ai/source.json")" || { echo "Error: unknown $provider profile: $profile" >&2; exit 1; }
  credential_ref="$(jq -r '.authentication.credentialRef // empty' <<<"$record")"
  [[ "$credential_ref" == "ai/secrets/$provider/"*.credentials.sops.yaml && "$credential_ref" != *".."* ]] || {
    echo "Error: invalid credentialRef for $provider/$profile" >&2; exit 1;
  }
  secret_file="$repo_dir/$credential_ref"
  local_file="$profile_root/$profile/$credential_name"
  mkdir -p "$(dirname "$secret_file")"

  if [[ "$action" == backup ]]; then
    [[ -f "$local_file" ]] || { echo "Skipped $provider/$profile: no local credential."; continue; }
    validate_plaintext "$local_file" || { echo "Error: unexpected local credential format: $provider/$profile" >&2; exit 1; }
    [[ ! -e "$secret_file" || "$force" == true ]] || { echo "Error: escrow exists; use --force to rotate: $provider/$profile" >&2; exit 1; }
    encrypted="$(mktemp "$(dirname "$secret_file")/.credential.XXXXXX.tmp")"
    decrypted="$(mktemp)"
    trap 'rm -f "${encrypted:-}" "${decrypted:-}"' EXIT
    (cd "$repo_dir" && sops encrypt --filename-override "$credential_ref" \
      --input-type json --output-type yaml "$local_file") > "$encrypted"
    sops decrypt --input-type yaml --output-type json "$encrypted" > "$decrypted"
    validate_plaintext "$decrypted" || { echo "Error: encrypted round trip failed: $provider/$profile" >&2; exit 1; }
    [[ "$(json_hash "$local_file")" == "$(json_hash "$decrypted")" ]] || {
      echo "Error: encrypted round-trip hash mismatch: $provider/$profile" >&2; exit 1;
    }
    chmod 600 "$encrypted"
    mv -f "$encrypted" "$secret_file"
    encrypted=""
    rm -f "$decrypted"
    decrypted=""
    echo "Backed up encrypted credentials: $provider/$profile"
    continue
  fi

  [[ -f "$secret_file" ]] || { echo "Skipped $provider/$profile: escrow unavailable."; continue; }
  decrypted="$(mktemp)"
  trap 'rm -f "${decrypted:-}"' EXIT
  sops decrypt --input-type yaml --output-type json "$secret_file" > "$decrypted"
  validate_plaintext "$decrypted" || { echo "Error: invalid decrypted credential: $provider/$profile" >&2; exit 1; }
  if [[ "$action" == check ]]; then
    echo "Verified encrypted credentials: $provider/$profile"
  elif [[ -e "$local_file" && "$force" == false ]]; then
    echo "Preserved existing credentials: $provider/$profile"
  else
    mkdir -p "$(dirname "$local_file")"
    chmod 700 "$(dirname "$local_file")"
    target_tmp="$(mktemp "$(dirname "$local_file")/.credential.XXXXXX.tmp")"
    chmod 600 "$target_tmp"
    cp "$decrypted" "$target_tmp"
    mv -f "$target_tmp" "$local_file"
    echo "Restored credentials: $provider/$profile"
  fi
  rm -f "$decrypted"
  decrypted=""
done
